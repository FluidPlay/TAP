Killed(severity, corpsetype)
{
	if( severity <= 25 )
	{
		corpsetype = 1;
		explode turretaxis type BITMAPONLY | BITMAP1;
		explode turretbase type BITMAPONLY | BITMAP1;
		explode turret1 type BITMAPONLY | BITMAP1;
		explode turret1spawner type BITMAPONLY | BITMAP1;
		explode turret2 type BITMAPONLY | BITMAP1;
		explode turret2spawner type BITMAPONLY | BITMAP1;
		explode turret3 type BITMAPONLY | BITMAP1;
		explode turret3spawner type BITMAPONLY | BITMAP1;
		explode wingBL type BITMAPONLY | BITMAP1;
		explode wingBR type BITMAPONLY | BITMAP1;
		explode wingFL type BITMAPONLY | BITMAP1;
		explode wingFR type BITMAPONLY | BITMAP1;
		return (corpsetype);
	}
	if( severity <= 50 )
	{
		corpsetype = 2;
		explode turretaxis type FALL | BITMAP1;
		explode turretbase type FALL | BITMAP1;
		explode turret1 type FALL | BITMAP1;
		explode turret1spawner type FALL | BITMAP1;
		explode turret2 type FALL | BITMAP1;
		explode turret2spawner type FALL | BITMAP1;
		explode turret3 type FALL | BITMAP1;
		explode turret3spawner type FALL | BITMAP1;
		explode wingBL type FALL | BITMAP1;
		explode wingBR type FALL | BITMAP1;
		explode wingFL type FALL | BITMAP1;
		explode wingFR type FALL | BITMAP1;
		return (corpsetype);
	}
	if( severity <= 99 )
	{
		corpsetype = 3;
		explode turretaxis type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turretbase type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret1spawner type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret2spawner type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret3 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret3spawner type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode wingBL type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode wingBR type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode wingFL type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode wingFR type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		return (corpsetype);
	}
	corpsetype = 3;
	explode turretaxis type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turretbase type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret1spawner type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret2spawner type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret3 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode turret3spawner type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode wingBL type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode wingBR type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode wingFL type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode wingFR type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
	return corpsetype;
}
