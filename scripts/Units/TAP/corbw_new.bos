#define TA			// This is a TA script

#include "sfxtype.h"
#include "exptype.h"

piece base_root, base, turretaxis, turretbase, turret1, turret1spawner, turret2, turret2spawner, turret3, turret3spawner, wingBL, wingBR, wingFL, wingFR;

static-var Static_Var_4; //Aiming Dgun

#define SIG_AIM				2

SmokeUnit(healthpercent, sleeptime, smoketype)
{
	while( get BUILD_PERCENT_LEFT )
	{
		sleep 400;
	}
	while( TRUE )
	{
		healthpercent = get HEALTH;
		if( healthpercent < 66 )
		{
			smoketype = 256 | 2;
			if( Rand( 1, 66 ) < healthpercent )
			{
				smoketype = 256 | 1;
			}
			emit-sfx smoketype from base;
		}
		sleeptime = healthpercent * 50;
		if( sleeptime < 200 )
		{
			sleeptime = 200;
		}
		sleep sleeptime;
	}
}

Create()
{
	//hide flare;
	//Static_Var_4 = 0;
	start-script SmokeUnit();
}

QueryPrimary(piecenum)
{
	piecenum = turret1spawner;
}

AimFromPrimary(piecenum)
{
	piecenum = turret1;
}

AimPrimary(heading, pitch)
{
	signal SIG_AIM;
	set-signal-mask SIG_AIM;
	turn turretaxis to y-axis heading speed <500.000000>;
	turn turretbase to x-axis <0.000000> - pitch speed <250.000000>;
	wait-for-turn turretaxis around y-axis;
	wait-for-turn turretbase around x-axis;
	return (1);
